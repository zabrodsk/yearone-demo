# Optional live narration providers. The judged/scored path works without these.
#
# MODEL_PROVIDER options:
# - auto: use OPENAI_API_KEY first, then ANTHROPIC_API_KEY, then local Claude Code OAuth, else local fallback
# - openai: require OPENAI_API_KEY
# - anthropic: require ANTHROPIC_API_KEY
# - claude-cli: use local Claude Code login/subscription
# - codex-cli: use local Codex CLI login/subscription
MODEL_PROVIDER=auto

# OpenAI SDK:
# OPENAI_API_KEY=<your-openai-api-key>
# OPENAI_MODEL=gpt-4.1-mini
#
# Claude SDK:
# ANTHROPIC_API_KEY=<your-anthropic-api-key>
# ANTHROPIC_MODEL=claude-sonnet-4-5
#
# Codex CLI:
# CODEX_MODEL=
